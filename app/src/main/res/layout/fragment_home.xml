<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Greeting -->
        <TextView
            android:id="@+id/tv_greeting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Good day"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Here is your budget summary for this month"
            android:textColor="@color/text_sub"
            android:textSize="13sp"
            android:layout_marginBottom="16dp"/>

        <!-- Total Spent Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPENT THIS MONTH"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tv_total_spent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R 0.00"
                    android:textColor="@color/teal"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/tv_budget_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No budget set"
                    android:textColor="@color/green_light"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <ProgressBar
                    android:id="@+id/progress_budget"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/teal"
                    android:progressBackgroundTint="@color/border"
                    android:visibility="invisible"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_budget_range"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/tv_no_budget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap the Goals tab to set a budget"
                    android:textColor="@color/amber"
                    android:textSize="12sp"
                    android:visibility="gone"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Quick-add button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_quick_add"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="+ Add Expense"
            android:textSize="14sp"
            app:backgroundTint="@color/teal_dark"
            android:textColor="@color/bg_dark"
            android:layout_marginBottom="20dp"/>

        <!-- Category mini-bars -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spending by Category"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_category_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="20dp"/>

        <!-- Recent Expenses -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recent Expenses"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_no_recent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No expenses yet - tap + Add Expense to get started."
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_recent_expenses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:paddingBottom="16dp"/>

    </LinearLayout>
</ScrollView>