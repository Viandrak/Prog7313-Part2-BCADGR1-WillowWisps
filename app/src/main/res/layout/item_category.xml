<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_card_dark"
    android:orientation="horizontal"
    android:padding="14dp"
    android:gravity="center_vertical">

    <View
        android:id="@+id/view_color_bar"
        android:layout_width="4dp"
        android:layout_height="44dp"
        android:layout_marginEnd="12dp"
        android:background="#2dd4bf"/>

    <TextView
        android:id="@+id/tv_cat_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:layout_marginEnd="10dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_cat_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#e2edf5"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_cat_budget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#4d6580"
            android:textSize="11sp"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_edit"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_edit"
        app:tint="#4d6580"/>

    <ImageButton
        android:id="@+id/btn_delete"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_delete"
        app:tint="#f87171"
        android:layout_marginStart="4dp"/>

</LinearLayout>