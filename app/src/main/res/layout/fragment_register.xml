<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080f14"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        android:paddingTop="56dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌱"
            android:textSize="48sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textColor="#d1fae5"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#f87171"
            android:textSize="12sp"
            android:padding="10dp"
            android:background="#1a0a0a"
            android:visibility="gone"
            android:layout_marginBottom="12dp"/>

        <!-- Display Name -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/bg_input_teal" android:paddingStart="14dp"
            android:paddingEnd="14dp" android:layout_marginBottom="12dp">
            <EditText android:id="@+id/et_display_name" android:layout_width="match_parent"
                android:layout_height="match_parent" android:hint="Display Name (optional)"
                android:textColor="#e2edf5" android:textColorHint="#4d6580"
                android:textSize="12sp" android:background="@null"
                android:imeOptions="actionNext"/>
        </LinearLayout>

        <!-- Username -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/bg_input_teal" android:paddingStart="14dp"
            android:paddingEnd="14dp" android:layout_marginBottom="12dp">
            <EditText android:id="@+id/et_username" android:layout_width="match_parent"
                android:layout_height="match_parent" android:hint="Username"
                android:textColor="#e2edf5" android:textColorHint="#4d6580"
                android:textSize="12sp" android:background="@null"
                android:inputType="textNoSuggestions" android:imeOptions="actionNext"/>
        </LinearLayout>

        <!-- Password -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/bg_input_teal" android:paddingStart="14dp"
            android:paddingEnd="14dp" android:layout_marginBottom="12dp">
            <EditText android:id="@+id/et_password" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:hint="Password" android:textColor="#e2edf5"
                android:textColorHint="#4d6580" android:textSize="12sp"
                android:background="@null" android:inputType="textPassword"
                android:imeOptions="actionNext"/>
            <ImageView
                android:id="@+id/btn_toggle_password"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_eye_open"
                android:padding="2dp"/>
        </LinearLayout>

        <!-- Confirm Password -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/bg_input_teal" android:paddingStart="14dp"
            android:paddingEnd="14dp" android:layout_marginBottom="24dp">
            <EditText android:id="@+id/et_confirm_password" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:hint="Confirm Password" android:textColor="#e2edf5"
                android:textColorHint="#4d6580" android:textSize="12sp"
                android:background="@null" android:inputType="textPassword"
                android:imeOptions="actionDone"/>
            <ImageView
                android:id="@+id/btn_toggle_confirm_password"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_eye_open"
                android:padding="2dp"/>
        </LinearLayout>

        <Button android:id="@+id/btn_register" android:layout_width="match_parent"
            android:layout_height="50dp" android:text="CREATE ACCOUNT"
            android:textColor="#0a1f0e" android:textStyle="bold" android:textSize="14sp"
            android:background="@drawable/bg_button_green"/>

        <ProgressBar android:id="@+id/progress_bar" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:layout_gravity="center"
            android:visibility="gone" android:indeterminateTint="#2dd4bf"
            android:layout_marginTop="8dp"/>

        <TextView android:id="@+id/tv_login" android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Already have an account? Log In"
            android:textColor="#2dd4bf" android:textSize="12sp"
            android:layout_marginTop="16dp" android:padding="8dp"/>
    </LinearLayout>
</ScrollView>