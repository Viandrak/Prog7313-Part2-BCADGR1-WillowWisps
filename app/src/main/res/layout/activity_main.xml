<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080F14">

    <FrameLayout
        android:id="@+id/main_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#111827">

        <Button
            android:id="@+id/btn_nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Home"
            android:textSize="11sp"
            android:textColor="#2dd4bf"
            android:background="@android:color/transparent" />

        <Button
            android:id="@+id/btn_nav_add"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Add"
            android:textSize="11sp"
            android:textColor="#7A9AB8"
            android:background="@android:color/transparent" />

        <Button
            android:id="@+id/btn_nav_categories"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Categories"
            android:textSize="11sp"
            android:textColor="#7A9AB8"
            android:background="@android:color/transparent" />

        <Button
            android:id="@+id/btn_nav_reports"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Reports"
            android:textSize="11sp"
            android:textColor="#7A9AB8"
            android:background="@android:color/transparent" />

        <Button
            android:id="@+id/btn_nav_goals"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Goals"
            android:textSize="11sp"
            android:textColor="#7A9AB8"
            android:background="@android:color/transparent" />

    </LinearLayout>
</LinearLayout>