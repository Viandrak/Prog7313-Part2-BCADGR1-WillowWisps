<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#111827">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Category Name"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxBackgroundColor="#161d2e" app:boxStrokeColor="#2dd4bf"
        app:hintTextColor="#4d6580" android:layout_marginBottom="14dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_category_name" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="#e2edf5"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Monthly Limit (R) — optional"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxBackgroundColor="#161d2e" app:boxStrokeColor="#2dd4bf"
        app:hintTextColor="#4d6580" android:layout_marginBottom="14dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_budget_limit" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="#e2edf5"
            android:inputType="numberDecimal"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Colour" android:textColor="#4d6580" android:textSize="12sp"
        android:layout_marginBottom="6dp"/>
    <Spinner android:id="@+id/spinner_color" android:layout_width="match_parent"
        android:layout_height="48dp" android:background="@drawable/bg_card_dark"
        android:paddingStart="12dp" android:layout_marginBottom="14dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Icon" android:textColor="#4d6580" android:textSize="12sp"
        android:layout_marginBottom="6dp"/>
    <Spinner android:id="@+id/spinner_icon" android:layout_width="match_parent"
        android:layout_height="48dp" android:background="@drawable/bg_card_dark"
        android:paddingStart="12dp"/>
</LinearLayout>