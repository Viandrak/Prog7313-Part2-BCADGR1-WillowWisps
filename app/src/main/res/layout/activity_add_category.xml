<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080f14"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="‹"
                android:textColor="#2dd4bf"
                android:textSize="28sp"
                android:paddingEnd="12dp"/>

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Category"
                android:textColor="#d1fae5"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="serif"/>
        </LinearLayout>

        <!-- Category Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CATEGORY NAME"
            android:textColor="#4d6580"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/et_category_name"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="e.g. Health &amp; Wellness"
            android:textColor="#e2edf5"
            android:textColorHint="#4d6580"
            android:textSize="14sp"
            android:background="@drawable/bg_input_teal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="24dp"/>

        <!-- Icon section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ICON"
            android:textColor="#4d6580"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp"/>

        <!-- Icon row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <TextView android:id="@+id/icon1" android:layout_width="0dp"
                android:layout_height="52dp" android:layout_weight="1"
                android:gravity="center" android:textSize="24sp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_card_dark"/>
            <TextView android:id="@+id/icon2" android:layout_width="0dp"
                android:layout_height="52dp" android:layout_weight="1"
                android:gravity="center" android:textSize="24sp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_card_dark"/>
            <TextView android:id="@+id/icon3" android:layout_width="0dp"
                android:layout_height="52dp" android:layout_weight="1"
                android:gravity="center" android:textSize="24sp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_card_dark"/>
            <TextView android:id="@+id/icon4" android:layout_width="0dp"
                android:layout_height="52dp" android:layout_weight="1"
                android:gravity="center" android:textSize="24sp"
                android:background="@drawable/bg_card_dark"/>
        </LinearLayout>

        <!-- Icon row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <TextView android:id="@+id/icon5" android:layout_width="0dp"
                android:layout_height="52dp" android:layout_weight="1"
                android:gravity="center" android:textSize="24sp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_card_dark"/>
            <TextView android:id="@+id/icon6" android:layout_width="0dp"
                android:layout_height="52dp" android:layout_weight="1"
                android:gravity="center" android:textSize="24sp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_card_dark"/>
            <TextView android:id="@+id/icon7" android:layout_width="0dp"
                android:layout_height="52dp" android:layout_weight="1"
                android:gravity="center" android:textSize="24sp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_card_dark"/>
            <TextView android:id="@+id/icon8" android:layout_width="0dp"
                android:layout_height="52dp" android:layout_weight="1"
                android:gravity="center" android:textSize="24sp"
                android:background="@drawable/bg_card_dark"/>
        </LinearLayout>

        <!-- Icon row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <TextView android:id="@+id/icon9" android:layout_width="0dp"
                android:layout_height="52dp" android:layout_weight="1"
                android:gravity="center" android:textSize="24sp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_card_dark"/>
            <TextView android:id="@+id/icon10" android:layout_width="0dp"
                android:layout_height="52dp" android:layout_weight="1"
                android:gravity="center" android:textSize="24sp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_card_dark"/>
            <TextView android:id="@+id/icon11" android:layout_width="0dp"
                android:layout_height="52dp" android:layout_weight="1"
                android:gravity="center" android:textSize="24sp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_card_dark"/>
            <TextView android:id="@+id/icon12" android:layout_width="0dp"
                android:layout_height="52dp" android:layout_weight="1"
                android:gravity="center" android:textSize="24sp"
                android:background="@drawable/bg_card_dark"/>
        </LinearLayout>

        <!-- Colour section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COLOUR"
            android:textColor="#4d6580"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp"/>

        <!-- Colour row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">
            <View android:id="@+id/color1" android:layout_width="36dp"
                android:layout_height="36dp" android:layout_marginEnd="10dp"/>
            <View android:id="@+id/color2" android:layout_width="36dp"
                android:layout_height="36dp" android:layout_marginEnd="10dp"/>
            <View android:id="@+id/color3" android:layout_width="36dp"
                android:layout_height="36dp" android:layout_marginEnd="10dp"/>
            <View android:id="@+id/color4" android:layout_width="36dp"
                android:layout_height="36dp" android:layout_marginEnd="10dp"/>
            <View android:id="@+id/color5" android:layout_width="36dp"
                android:layout_height="36dp" android:layout_marginEnd="10dp"/>
            <View android:id="@+id/color6" android:layout_width="36dp"
                android:layout_height="36dp"/>
        </LinearLayout>

        <!-- Colour row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <View android:id="@+id/color7" android:layout_width="36dp"
                android:layout_height="36dp" android:layout_marginEnd="10dp"/>
            <View android:id="@+id/color8" android:layout_width="36dp"
                android:layout_height="36dp" android:layout_marginEnd="10dp"/>
            <View android:id="@+id/color9" android:layout_width="36dp"
                android:layout_height="36dp" android:layout_marginEnd="10dp"/>
            <View android:id="@+id/color10" android:layout_width="36dp"
                android:layout_height="36dp" android:layout_marginEnd="10dp"/>
            <View android:id="@+id/color11" android:layout_width="36dp"
                android:layout_height="36dp"/>
        </LinearLayout>

        <!-- Monthly budget -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MONTHLY BUDGET"
            android:textColor="#4d6580"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input_teal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R"
                android:textColor="#4d6580"
                android:textSize="14sp"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/et_budget"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="500"
                android:textColor="#e2edf5"
                android:textColorHint="#4d6580"
                android:textSize="14sp"
                android:gravity="center"
                android:background="@null"
                android:inputType="numberDecimal"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="per month"
                android:textColor="#4d6580"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Save button -->
        <Button
            android:id="@+id/btn_save_category"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="SAVE CATEGORY"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:textSize="14sp"
            android:letterSpacing="0.08"
            android:background="@drawable/bg_button_purple"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This category will appear in Add Expense"
            android:textColor="#4d6580"
            android:textSize="12sp"
            android:gravity="center"/>

    </LinearLayout>
</ScrollView>